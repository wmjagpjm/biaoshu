# 标书后端环境变量示例（复制为 .env 后按需修改；勿提交真实密钥）

# SQLite 路径（相对 backend 工作目录，或绝对路径）
DATABASE_URL=sqlite:///./data/biaoshu.db

# 个人版默认工作空间
DEFAULT_WORKSPACE_ID=ws_local
DEFAULT_WORKSPACE_NAME=我的工作空间
DEFAULT_OWNER_USER_ID=user_local

# 开发 CORS（逗号分隔；仅本机回环。可信内网走 Vite 同源 /api 代理，勿为 LAN 扩 CORS）
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# 鉴权模式：disabled=本机个人兼容默认；required=强制登录会话。
# 可信内网（V1-L）启动脚本会在后端子进程瞬时注入 AUTH_MODE=required，勿把口令/密钥写入本文件。
# 浏览器只访问 Vite:5173；后端保持 127.0.0.1:8000，禁止把 8000 暴露到局域网。
# AUTH_MODE=disabled

# 上传目录与大小
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=52428800

# 正文图片：仅 PNG/JPEG/GIF，独立限制避免占满导出内存
MAX_IMAGE_UPLOAD_BYTES=5242880
MAX_IMAGE_PIXELS=67108864
MAX_PROJECT_IMAGES=50

# 本地标讯离线导入：仅 CSV/JSON，文件在请求内存解析，不落盘
MAX_OPPORTUNITY_IMPORT_BYTES=2097152
MAX_OPPORTUNITY_IMPORT_ROWS=2000

# 本地演示标讯：默认关闭，避免空工作空间被示例数据污染
SEED_SAMPLE_OPPORTUNITIES=false

# 受控资源同步：默认无来源。仅配置已签名 HTTPS 清单，主机必须同时列入精确白名单；勿填私钥、Token、Cookie 或内部地址。
# RESOURCE_SYNC_SOURCES=[{"id":"official-guides","label":"官方写作指南","manifestUrl":"https://publisher.example/resources.json","publicKey":"Base64Ed25519公钥"}]
# RESOURCE_SYNC_ALLOWED_HOSTS=publisher.example
RESOURCE_SYNC_MAX_BYTES=1048576
RESOURCE_SYNC_TIMEOUT_SECONDS=10

# 本地 MinerU 回传 Token（空=不校验）
LOCAL_PARSER_TOKEN=
