# 标书后端环境变量示例（复制为 .env 后按需修改；勿提交真实密钥）

# SQLite 路径（相对 backend 工作目录，或绝对路径）
DATABASE_URL=sqlite:///./data/biaoshu.db

# 个人版默认工作空间
DEFAULT_WORKSPACE_ID=ws_local
DEFAULT_WORKSPACE_NAME=我的工作空间
DEFAULT_OWNER_USER_ID=user_local

# 开发 CORS（逗号分隔）
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# 上传目录与大小
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=52428800

# 本地 MinerU 回传 Token（空=不校验）
LOCAL_PARSER_TOKEN=
